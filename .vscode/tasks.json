{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SDL2 Program",
            "type": "shell",
            "command": "g++",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-IC:\\msys64\\ucrt64\\include\\SDL2",
                "-LC:\\msys64\\ucrt64\\lib",
                "-lmingw32",
                "-lSDL2main",
                "-lSDL2",
                "-mwindows"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}